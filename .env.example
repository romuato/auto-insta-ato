# ============================================================
#  EXEMPLE de configuration.
#  Copiez ce fichier en ".env" et remplissez vos vraies valeurs.
#  NE JAMAIS partager le fichier .env (il contient vos secrets).
# ============================================================

# --- OpenAI (generation texte + image) ---
OPENAI_API_KEY=sk-remplacez-par-votre-cle

# --- Instagram / Meta (publication) ---
IG_USER_ID=000000000000000
IG_ACCESS_TOKEN=remplacez-par-votre-token-longue-duree
# Page Facebook pro (ex. "A T O"). Laissez vide pour ne publier que sur Instagram.
FB_PAGE_ID=

# --- Hebergement image, MODE LOCAL uniquement (PC) : Cloudinary gratuit ---
# (Inutile si vous utilisez le mode cloud GitHub Actions.)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Options ---
# POST_SLOT : 0 pour le post du matin, 1 pour celui du soir (2 posts/jour)
POST_SLOT=0
# DRY_RUN=1 pour tester sans publier reellement
DRY_RUN=
